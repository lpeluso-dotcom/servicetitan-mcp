# Local development placeholders only. Do NOT put real production values here.
# In production, set these with `wrangler secret put <NAME>` instead of a file.

# ── ServiceTitan app credentials (Developer Portal → Settings → API Application) ──
ST_CLIENT_ID=replace-with-servicetitan-client-id
ST_CLIENT_SECRET=replace-with-servicetitan-client-secret
ST_APP_KEY=replace-with-servicetitan-app-key

# ── Inbound auth: MCP clients send this value as the X-Sync-Key header ──
MCP_SYNC_KEY=replace-with-a-long-random-string

# ── Optional ──
# JWT_SECRET=at-least-32-random-bytes-if-you-use-jwt-client-auth
# ST_WEBHOOK_SECRET=replace-if-you-enable-POST-/webhooks/st
